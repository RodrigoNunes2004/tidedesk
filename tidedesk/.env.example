# =============================================================================
# TideDesk – Environment Variables
# Copy to .env and fill in your values. Never commit .env to git.
# =============================================================================

# Database (Neon PostgreSQL)
DATABASE_URL="postgresql://user:password@host.neon.tech/dbname?sslmode=require"

# Auth (NextAuth)
NEXTAUTH_SECRET="generate-with-openssl-rand-base64-32"
NEXTAUTH_URL="http://localhost:3000"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Stripe (Dashboard → Developers → API keys, Products → Price ID)
STRIPE_SECRET_KEY="your-stripe-secret-key"
STRIPE_PRICE_ID="your-stripe-price-id"
# Multi-tier: set these for Starter ($69), Pro ($129), Premium ($199)
# STRIPE_PRICE_ID_STARTER="price_..."
# STRIPE_PRICE_ID_PRO="price_..."
# STRIPE_PRICE_ID_PREMIUM="price_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="your-stripe-publishable-key"

# Stripe Webhooks (Dashboard → Developers → Webhooks; add endpoint /api/webhooks/stripe)
# Required for Connect account.updated and payment events.
STRIPE_WEBHOOK_SECRET="whsec_..."

# Twilio (SMS – optional; leave empty to skip SMS)
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_PHONE_NUMBER=""

# Resend (Email – booking confirmation, reminders, payment receipts)
RESEND_API_KEY=""
RESEND_FROM="TideDesk <onboarding@resend.dev>"

# Cron (optional – secure cron endpoint; set in Vercel)
CRON_SECRET=""

# Stormglass (Weather engine – marine forecast & alerts)
STORMGLASS_API_KEY=""

# Upstash Redis (Rate limiting for public APIs – optional; create at console.upstash.com)
# Without these, public APIs have no rate limit.
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# Vercel Blob (production – persistent avatar storage; create store in Vercel Dashboard)
# Without this, avatars use local disk and will not persist on Vercel.
# BLOB_READ_WRITE_TOKEN="vercel_blob_rw_..."

# -----------------------------------------------------------------------------
# Production (Vercel): use https://your-app.vercel.app for NEXTAUTH_URL and
# NEXT_PUBLIC_APP_URL. Use sk_live_* and pk_live_* for Stripe.
# -----------------------------------------------------------------------------
